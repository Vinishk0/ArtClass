<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!-- Art studio palette — warm, tactile, confident -->
  <Color x:Key="Canvas">#FAF7F2</Color>
  <Color x:Key="CanvasDark">#141210</Color>
  <Color x:Key="Surface">#FFFFFF</Color>
  <Color x:Key="SurfaceDark">#1E1C1A</Color>
  <Color x:Key="SurfaceElevated">#FFFDF9</Color>
  <Color x:Key="SurfaceElevatedDark">#2A2724</Color>

  <Color x:Key="Primary">#C45C3E</Color>
  <Color x:Key="PrimaryDark">#E07A5F</Color>
  <Color x:Key="PrimaryMuted">#F4E4DE</Color>
  <Color x:Key="PrimaryMutedDark">#3D2A24</Color>

  <Color x:Key="Secondary">#5B7B6A</Color>
  <Color x:Key="SecondaryDark">#7FA08E</Color>
  <Color x:Key="SecondaryMuted">#E8F0EB</Color>
  <Color x:Key="SecondaryMutedDark">#243028</Color>

  <Color x:Key="Accent">#D4A853</Color>
  <Color x:Key="AccentDark">#E8C078</Color>

  <Color x:Key="TextPrimary">#1C1917</Color>
  <Color x:Key="TextPrimaryDark">#F5F2ED</Color>
  <Color x:Key="TextSecondary">#78716C</Color>
  <Color x:Key="TextSecondaryDark">#A8A29E</Color>
  <Color x:Key="TextTertiary">#A8A29E</Color>
  <Color x:Key="TextTertiaryDark">#78716C</Color>

  <Color x:Key="Border">#E7E0D5</Color>
  <Color x:Key="BorderDark">#3D3834</Color>
  <Color x:Key="Divider">#F0EBE3</Color>
  <Color x:Key="DividerDark">#2E2A27</Color>

  <Color x:Key="TodayBg">#FEF3C7</Color>
  <Color x:Key="TodayBgDark">#3D3520</Color>
  <Color x:Key="TodayRing">#D4A853</Color>

  <Color x:Key="Danger">#B91C1C</Color>
  <Color x:Key="DangerDark">#F87171</Color>
  <Color x:Key="Success">#5B7B6A</Color>

  <Color x:Key="White">#FFFFFF</Color>
  <Color x:Key="Black">#000000</Color>
  <Color x:Key="Transparent">#00000000</Color>

  <!-- Legacy aliases for compatibility -->
  <Color x:Key="PrimaryDarkText">#F5F2ED</Color>
  <Color x:Key="SecondaryDarkText">#E07A5F</Color>
  <Color x:Key="Tertiary">#8B3A2A</Color>
  <Color x:Key="Magenta">#C45C3E</Color>
  <Color x:Key="MidnightBlue">#1C1917</Color>
  <Color x:Key="OffBlack">#141210</Color>
  <Color x:Key="Gray100">#F0EBE3</Color>
  <Color x:Key="Gray200">#E7E0D5</Color>
  <Color x:Key="Gray300">#D6D0C7</Color>
  <Color x:Key="Gray400">#A8A29E</Color>
  <Color x:Key="Gray500">#78716C</Color>
  <Color x:Key="Gray600">#57534E</Color>
  <Color x:Key="Gray900">#1C1917</Color>
  <Color x:Key="Gray950">#141210</Color>

  <SolidColorBrush x:Key="CanvasBrush" Color="{AppThemeBinding Light={StaticResource Canvas}, Dark={StaticResource CanvasDark}}" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}" />
  <SolidColorBrush x:Key="PrimaryBrush" Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
  <SolidColorBrush x:Key="BorderBrush" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" />

</ResourceDictionary>
