<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ArtClass.ViewModels"
             x:Class="ArtClass.Views.SchedulePage"
             x:DataType="vm:ScheduleViewModel"
             Title="Расписание">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,12">
            <Label Text="Художественная школа"
                   Style="{StaticResource Headline}" />
            <Label Text="{Binding StatusMessage}"
                   Style="{StaticResource SubHeadline}" />
            <Button Text="Обновить"
                    Command="{Binding LoadScheduleCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Start" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Lessons}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:LessonItemViewModel">
                    <Border Margin="0,0,0,8"
                            Padding="12"
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding DayName}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="{Binding TimeRange}"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Title}" />
                            <Label Text="{Binding Details}"
                                   TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
