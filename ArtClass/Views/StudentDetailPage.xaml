<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ArtClass.ViewModels"
             x:Class="ArtClass.Views.StudentDetailPage"
             x:DataType="vm:StudentDetailViewModel"
             Title="Ученик">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Изменить" Command="{Binding EditCommand}" />
        <ToolbarItem Text="Удалить" Command="{Binding DeleteCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="16" Style="{StaticResource PageRoot}">

            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Border Grid.Column="0"
                            WidthRequest="56"
                            HeightRequest="56"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryMuted}, Dark={StaticResource PrimaryMutedDark}}"
                            VerticalOptions="Start">
                        <Label Text="{Binding Initials}"
                               FontFamily="OpenSansSemibold"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="{Binding FullName}" Style="{StaticResource TitleLarge}" />
                        <Label Text="{Binding Phone, StringFormat='📞 {0}'}" Style="{StaticResource BodySecondary}" />
                        <Label Text="{Binding Age, StringFormat='Возраст: {0} лет'}" Style="{StaticResource BodySecondary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label Text="Группы" Style="{StaticResource Overline}" />
                <Border Style="{StaticResource CardCompact}">
                    <CollectionView ItemsSource="{Binding Groups}">
                        <CollectionView.EmptyView>
                            <Label Text="Не состоит в группах"
                                   Style="{StaticResource BodySecondary}"
                                   Padding="8" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnDefinitions="Auto,*" Padding="4,6" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="🎨" FontSize="14" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding .}" Style="{StaticResource Body}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
