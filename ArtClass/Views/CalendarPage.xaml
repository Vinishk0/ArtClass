<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

             xmlns:vm="clr-namespace:ArtClass.ViewModels"

             x:Class="ArtClass.Views.CalendarPage"

             x:DataType="vm:CalendarViewModel"

             Title="Календарь">



    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="20,16,20,8"
          Style="{StaticResource PageRoot}">



        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,16">

            <Label Text="РАСПИСАНИЕ" Style="{StaticResource Overline}" />

            <Label Text="{Binding MonthTitle}" Style="{StaticResource Display}" />

        </VerticalStackLayout>



        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">

            <Button Grid.Column="0"
                    Text="‹"
                    Style="{StaticResource IconButton}"
                    Command="{Binding PreviousMonthCommand}" />
            <Button Grid.Column="1"
                    Text="Сегодня"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding GoTodayCommand}"
                    HorizontalOptions="Center"
                    WidthRequest="120" />
            <Button Grid.Column="2"
                    Text="›"
                    Style="{StaticResource IconButton}"
                    Command="{Binding NextMonthCommand}" />

        </Grid>



        <Grid Grid.Row="2"

              ColumnDefinitions="*,*,*,*,*,*,*"

              Margin="0,0,0,6">

            <Label Grid.Column="0" Text="Пн" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="1" Text="Вт" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="2" Text="Ср" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="3" Text="Чт" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="4" Text="Пт" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="5" Text="Сб" Style="{StaticResource WeekdayHeader}" />

            <Label Grid.Column="6" Text="Вс" Style="{StaticResource WeekdayHeader}" />

        </Grid>



        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="8"
                VerticalOptions="Start">
            <Grid x:Name="CalendarGrid"
                  RowDefinitions="*,*,*,*,*,*"
                  ColumnDefinitions="*,*,*,*,*,*,*"
                  ColumnSpacing="3"
                  RowSpacing="3"
                  HorizontalOptions="Fill"
                  VerticalOptions="Start" />
        </Border>

    </Grid>

</ContentPage>

