<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ArtClass.ViewModels"
             x:Class="ArtClass.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="20" Style="{StaticResource PageRoot}">

            <VerticalStackLayout Spacing="4">
                <Label Text="Студия" Style="{StaticResource Overline}" />
                <Label Text="Настройки" Style="{StaticResource Display}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Двухнедельный цикл" Style="{StaticResource TitleMedium}" />
                    <Label Text="Группы работают по 2-недельному расписанию. Каждые две недели слоты сдвигаются на следующую неделю цикла."
                           Style="{StaticResource BodySecondary}" />
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource BorderDark}}" />
                    <Label Text="{Binding CycleInfo}"
                           Style="{StaticResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Сдвиг расписания" Style="{StaticResource TitleMedium}" />
                    <Label Text="Переводит все группы на следующую неделю цикла и удаляет прошедшие разовые уроки."
                           Style="{StaticResource BodySecondary}" />
                    <Button Text="Сдвинуть цикл на 2 недели"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RollScheduleCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    <Label Text="{Binding StatusMessage}"
                           Style="{StaticResource BodySecondary}"
                           TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SecondaryDark}}"
                           IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="База данных" Style="{StaticResource TitleMedium}" />
                    <Label Text="Файл SQLite с группами, учениками и расписанием."
                           Style="{StaticResource BodySecondary}" />
                    <Label Text="{Binding DatabasePath}"
                           Style="{StaticResource Caption}"
                           LineBreakMode="CharacterWrap"
                           FontFamily="OpenSansSemibold" />
                    <Label Text="{Binding DatabaseHint}"
                           Style="{StaticResource Caption}"
                           LineBreakMode="WordWrap" />
                    <Button Text="Сбросить базу данных"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ResetDatabaseCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="ArtClass · расписание художественной студии"
                   Style="{StaticResource Caption}"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
